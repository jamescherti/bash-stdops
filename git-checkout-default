set -Eeuo pipefail

readonly REMOTE="${REMOTE:-origin}"

# shellcheck disable=SC2317
error_handler() {
  local errno="$?"
  echo "Error: ${BASH_SOURCE[1]}:${BASH_LINENO[0]}" \
    "(${BASH_COMMAND} exited with status $errno)" >&2
  exit "${errno}"
}

require_git_repository() {
  git rev-parse --git-dir >/dev/null 2>&1 \
    || {
      echo "Error: Not a git repository." >&2
      exit 1
    }
}

require_command() {
  command -v "$1" >/dev/null 2>&1 \
    || {
      echo "Error: Required command '$1' not found in PATH." >&2
      exit 1
    }
}

get_default_branch() {
  git symbolic-ref --quiet --short "refs/remotes/${REMOTE}/HEAD" 2>/dev/null \
    | sed "s@^${REMOTE}/@@"
}

fallback_default_branch() {
  local candidate
  for candidate in main master; do
    if git show-ref --verify --quiet "refs/remotes/${REMOTE}/${candidate}"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

get_current_branch() {
  git symbolic-ref --quiet --short HEAD 2>/dev/null
}

main() {
  require_git_repository
  require_command git-is-clean

  local default_branch
  if ! default_branch="$(get_default_branch)" || [ -z "$default_branch" ]; then
    if default_branch="$(fallback_default_branch)"; then
      echo "Warning: Default branch not detected from remote HEAD. Falling" \
        "back to ${default_branch}."
    else
      echo "Error: Could not determine default branch" \
        "for remote '${REMOTE}'." >&2
      exit 1
    fi
  fi

  git-is-clean || exit 1

  local current_branch
  current_branch="$(get_current_branch || echo HEAD)"

  if [ "$current_branch" = "$default_branch" ]; then
    echo "Already on default branch: ${default_branch}"
    return 0
  fi

  echo "git checkout ${default_branch}"
  git checkout --quiet "$default_branch"
}

main "$@"
