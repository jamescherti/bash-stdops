set -euo pipefail
IFS=$'\n\t'

# Global configuration variables
GIT_CHECK_GPG_DATA_DIR="${GIT_CHECK_GPG_DATA_DIR:-$HOME/.git-check-gpg}"
IGNORE_DIR="$GIT_CHECK_GPG_DATA_DIR/ignore"
ACCEPT_DIR="$GIT_CHECK_GPG_DATA_DIR/accept"

GIT_CHECK_GPG_INTERACTIVE=0
GIT_CHECK_GPG_AUTO_YES=0

show_usage() {
  echo "Usage: git-check-gpg [-i] [-y] [-h]"
  echo
  echo "Options:"
  echo "  -i  Interactive mode: prompt to ignore unsigned/invalid commits"
  echo "  -y  Auto-yes: ignore unsigned/invalid commits without prompting"
  echo "  -h  Display this help menu"
}

parse_args() {
  while getopts "ihy" opt; do
    case ${opt} in
    i)
      GIT_CHECK_GPG_INTERACTIVE=1
      ;;
    y)
      GIT_CHECK_GPG_AUTO_YES=1
      ;;
    h)
      show_usage
      exit 0
      ;;
    \?)
      show_usage >&2
      exit 1
      ;;
    esac
  done
}

main() {
  parse_args "$@"

  local amount_commits=0
  local commit=""
  local error=0
  local list_commits=()

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: the current directory '$(pwd)' is not a Git repository." >&2
    exit 1
  fi

  if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    echo
    echo "Error: no commits were found in the directory '$(pwd)'." >&2
    exit 1
  fi

  readarray -t list_commits < <(git rev-list HEAD)
  if [[ ${#list_commits[@]} -eq 0 ]]; then
    echo
    echo "Error: no commits were found in the directory '$(pwd)'." >&2
    exit 1
  fi

  # Ensure the configuration directories exist
  mkdir -p "$IGNORE_DIR" "$ACCEPT_DIR"

  for commit in "${list_commits[@]}"; do
    amount_commits=$((amount_commits + 1))

    # Skip commits that were previously ignored
    if [[ -f "$IGNORE_DIR/$commit" ]]; then
      continue
    fi

    # Skip checking commits that were previously verified and accepted
    if [[ -f "$ACCEPT_DIR/$commit" ]]; then
      continue
    fi

    # Check the GPG signature
    if git verify-commit "$commit" >/dev/null 2>&1; then
      touch "$ACCEPT_DIR/$commit"
    else
      if [[ $GIT_CHECK_GPG_AUTO_YES -eq 1 ]]; then
        touch "$IGNORE_DIR/$commit"
        continue
      elif [[ $GIT_CHECK_GPG_INTERACTIVE -eq 1 ]]; then
        printf '%.0s=' {1..80}
        echo
        git show --show-signature "$commit"
        printf '%.0s=' {1..80}
        echo

        local response
        # Read from /dev/tty to ensure it works even if stdin is redirected
        read -r -p \
          "Invalid signature detected. Always ignore this commit? [y/N] " \
          response </dev/tty

        if [[ $response =~ ^[Yy]$ ]]; then
          touch "$IGNORE_DIR/$commit"
          continue
        fi
      else
        echo "[ERROR] Failed to validate the GPG signature of" \
          "commit: $commit" >&2
        exit 1
      fi

      error=$((error + 1))
      break
    fi
  done

  if [[ $error -eq 0 ]]; then
    echo "[SUCCESS] GPG signatures of all the checked commits" \
      "are valid ($amount_commits commits)."
  else
    echo "[ERROR] Error with:"
    git show --show-signature "$commit"
    echo
    echo "[ERROR] Failed to validate the GPG signature of" \
      "the commit: $commit" >&2
    exit 1
  fi

  exit 0
}

main "$@"
