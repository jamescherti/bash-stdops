set -euf -o pipefail

main() {
  if [[ $# -lt 2 ]]; then
    printf "Usage: %s <lockfile> <command> [args...]\n" "$0" >&2
    exit 1
  fi

  local lockfile="$1"
  shift
  local cmd=("$@")
  local command_name="${cmd[0]}"

  # Ensure secure permissions for the lockfile creation
  local old_umask
  old_umask=$(umask)
  umask 077

  # Open file descriptor 200 for the lockfile
  exec 200>"$lockfile"
  umask "$old_umask"

  # Attempt to acquire an exclusive, non-blocking lock
  if ! flock -x -n 200; then
    printf "Error: Another instance of '%s' is running. " "$command_name" >&2
    printf \
      "To be able to run the program again, delete the lock file: '%s'.\n" \
      "$lockfile" >&2
    exit 1
  fi

  # Ensure the lockfile is removed when the script exits
  trap 'rm -f "$lockfile"; exec 200>&-' EXIT

  # Execute the provided command
  "${cmd[@]}"
}

main "$@"
