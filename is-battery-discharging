set -euf -o pipefail

main() {
  local list_batteries

  # Enable nullglob to safely handle systems with no battery matching the
  # pattern
  shopt -s nullglob
  list_batteries=(/sys/class/power_supply/BAT*)
  shopt -u nullglob

  if ((${#list_batteries[@]} == 0)); then
    exit 1
  fi

  local status
  local battery
  local battery_discharging=0
  local battery_charging=0

  for battery in "${list_batteries[@]}"; do
    if [[ -f "$battery/status" ]]; then
      # Read the file directly to avoid subshells and external binaries
      read -r status <"$battery/status"

      if [[ "$status" == *Discharging* ]]; then
        battery_discharging=$((battery_discharging + 1))
      else
        battery_charging=$((battery_charging + 1))
      fi
    fi
  done

  if ((battery_discharging > 0 && battery_charging == 0)); then
    exit 0
  fi

  exit 1
}

main "$@"
